<!--pages/index/index.wxml-->
<view class="container index-container">
  <view class="status-bar">
    <view class="status-item {{navState === 'UNLOCATED' ? 'inactive' : 'active'}}">
      <view class="status-dot"></view>
      <text class="status-text">{{navStateText}}</text>
    </view>
  </view>

  <view class="nav-progress-section" wx:if="{{navState === 'NAVIGATING'}}">
    <view class="card nav-progress-card">
      <text class="nav-progress-title">导航进行中</text>
      <text class="nav-progress-desc">可继续按指引扫码校准，或先返回地图查看当前楼层。</text>
      <view class="nav-progress-actions">
        <button class="btn btn-primary" bindtap="continueNavigation">继续导航</button>
        <button class="btn btn-secondary" bindtap="openMapFromHome">查看地图</button>
        <button class="btn btn-secondary" bindtap="stopNavigation">结束导航</button>
      </view>
    </view>
  </view>

  <view class="nav-progress-section" wx:if="{{navState === 'ARRIVED'}}">
    <view class="card nav-progress-card">
      <text class="nav-progress-title">已到达目的地</text>
      <text class="nav-progress-desc">可以结束本次导航，或重新选择目的地发起下一次导航。</text>
      <view class="nav-progress-actions">
        <button class="btn btn-primary" bindtap="stopNavigation">完成并返回就绪</button>
      </view>
    </view>
  </view>

  <view class="scan-section" wx:if="{{navState === 'UNLOCATED'}}">
    <view class="scan-card">
      <view class="scan-icon-container" bindtap="handleScan">
        <image class="scan-icon" src="/images/scan.png" mode="aspectFit"></image>
      </view>
      <text class="scan-title">扫码定位</text>
      <text class="scan-desc">扫描附近二维码，确定您的当前位置</text>
      <button class="btn btn-primary scan-btn" bindtap="handleScan">
        <text>开始扫码</text>
      </button>
    </view>
  </view>

  <view class="location-section" wx:if="{{navState === 'READY'}}">
    <view class="card location-card">
      <view class="location-header">
        <image class="location-icon" src="/images/location.png" mode="aspectFit"></image>
        <text class="location-title">当前位置</text>
      </view>
      <view class="location-info">
        <text class="location-name">{{currentLocation.name || '未命名位置'}}</text>
        <text class="location-detail">{{currentLocation.description || ''}}</text>
        <view class="location-tags" wx:if="{{currentLocation.tags}}">
          <text class="tag tag-primary" wx:for="{{currentLocation.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <button class="btn btn-secondary" bindtap="handleReScan">
        <text>重新扫码</text>
      </button>
    </view>
  </view>

  <view class="destination-section" wx:if="{{navState === 'READY'}}">
    <view class="card destination-card">
      <view class="destination-header">
        <image class="destination-icon" src="/images/destination.png" mode="aspectFit"></image>
        <text class="destination-title">选择目的地</text>
      </view>

      <view class="search-box">
        <image class="search-icon" src="/images/search.png" mode="aspectFit"></image>
        <input
          class="search-input"
          type="text"
          placeholder="搜索科室、地点或设施"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
          bindconfirm="onSearchConfirm"
        />
        <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</view>
      </view>

      <view class="filter-row">
        <picker
          class="filter-picker"
          mode="selector"
          range="{{floorOptions}}"
          value="{{floorFilterIndex}}"
          bindchange="onFloorFilterChange"
        >
          <view class="filter-chip">楼层：{{floorOptions[floorFilterIndex]}}</view>
        </picker>
        <picker
          class="filter-picker"
          mode="selector"
          range="{{typeOptions}}"
          value="{{typeFilterIndex}}"
          bindchange="onTypeFilterChange"
        >
          <view class="filter-chip">类型：{{typeOptions[typeFilterIndex]}}</view>
        </picker>
      </view>

      <view class="quick-destinations" wx:if="{{!searchKeyword}}">
        <text class="section-title">可选目的地</text>
        <view class="destination-grid">
          <view
            class="destination-item {{selectedDestination && selectedDestination.id === item.id ? 'selected' : ''}}"
            wx:for="{{pagedDestinations}}"
            wx:key="id"
            bindtap="selectDestination"
            data-item="{{item}}"
          >
            <text class="item-name">{{item.name}}</text>
            <text class="item-floor">{{item.floor}} {{item.typeLabel}}</text>
          </view>
        </view>
        <view class="pagination-row" wx:if="{{totalPages > 1}}">
          <button class="page-btn" bindtap="goPrevPage" disabled="{{currentPage <= 1}}">上一页</button>
          <text class="page-indicator">{{currentPage}} / {{totalPages}}</text>
          <button class="page-btn" bindtap="goNextPage" disabled="{{currentPage >= totalPages}}">下一页</button>
        </view>
      </view>

      <view class="search-results" wx:if="{{searchKeyword}}">
        <view wx:if="{{searchResults.length === 0}}" class="no-results">
          <image class="no-results-icon" src="/images/search.png" mode="aspectFit"></image>
          <text>未找到相关地点</text>
        </view>
        <view
          class="result-item {{selectedDestination && selectedDestination.id === item.id ? 'selected' : ''}}"
          wx:for="{{searchResults}}"
          wx:key="id"
          bindtap="selectDestination"
          data-item="{{item}}"
        >
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <text class="result-detail">{{item.floor}} {{item.typeLabel}}</text>
          </view>
          <view class="result-distance" wx:if="{{item.distance}}">
            <text>{{item.distance}}m</text>
          </view>
        </view>
      </view>

      <view class="selected-destination" wx:if="{{selectedDestination}}">
        <view class="selected-info">
          <image class="selected-icon" src="/images/destination.png" mode="aspectFit"></image>
          <view class="selected-text">
            <text class="selected-name">{{selectedDestination.name}}</text>
            <text class="selected-detail">{{selectedDestination.floor}} {{selectedDestination.description || ''}}</text>
          </view>
        </view>
        <view class="selected-actions">
          <button class="btn btn-primary" bindtap="startNavigation">
            <text>开始导航</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="recent-section" wx:if="{{recentDestinations.length > 0 && navState === 'READY'}}">
    <view class="card recent-card">
      <view class="history-header">
        <text class="history-title">最近到访目的地</text>
      </view>
      <view class="destination-grid recent-grid">
        <view
          class="destination-item {{selectedDestination && selectedDestination.id === item.id ? 'selected' : ''}}"
          wx:for="{{recentDestinations}}"
          wx:key="id"
          bindtap="selectDestination"
          data-item="{{item}}"
        >
          <text class="item-name">{{item.name}}</text>
          <text class="item-floor">{{item.typeLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
