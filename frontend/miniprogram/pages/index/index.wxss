/**pages/index/index.wxss**/
.index-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890ff 0%, #f5f5f5 30%);
  padding: 0;
}

/* 状态栏 */
.status-bar {
  padding: 40rpx 32rpx 32rpx;
}

.status-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.status-item.active .status-dot {
  background: #52c41a;
  animation: pulse 2s infinite;
}

.status-item.inactive .status-dot {
  background: #8c8c8c;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-text {
  font-size: 26rpx;
  color: #262626;
  font-weight: 500;
}

/* 扫码区域 */
.scan-section {
  padding: 0 32rpx;
}

.scan-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.scan-icon-container {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(24, 144, 255, 0.3);
  transition: transform 0.3s ease;
}

.scan-icon-container:active {
  transform: scale(0.95);
}

.scan-icon {
  width: 100rpx;
  height: 100rpx;
  filter: brightness(0) invert(1);
}

.scan-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
}

.scan-desc {
  display: block;
  font-size: 28rpx;
  color: #8c8c8c;
  margin-bottom: 48rpx;
}

.scan-btn .btn-icon {
  margin-right: 12rpx;
}

/* 位置确认区域 */
.location-section {
  padding: 0 32rpx;
}

.location-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.location-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.location-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.location-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.location-info {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.location-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 12rpx;
}

.location-detail {
  display: block;
  font-size: 28rpx;
  color: #595959;
}

.location-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* 目的地选择区域 */
.destination-section {
  padding: 32rpx;
}

.destination-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.destination-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.destination-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.destination-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #262626;
}

.search-placeholder {
  color: #8c8c8c;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #8c8c8c;
}

/* 快捷目的地 */
.quick-destinations {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #595959;
  margin-bottom: 24rpx;
}

.destination-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.destination-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  min-height: 140rpx;
}

.destination-item.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.destination-item:active {
  transform: scale(0.96);
}

.item-name {
  font-size: 35rpx;
  color: #262626;
  font-weight: 600;
  text-align: center;
}

.item-floor {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

/* 搜索结果 */
.search-results {
  margin-bottom: 32rpx;
}

.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.no-results-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.no-results text {
  font-size: 28rpx;
  color: #8c8c8c;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  transition: background 0.2s;
}

.result-item.selected {
  background: #e6f7ff;
}

.result-item:last-child {
  border-bottom: none;
}

.result-info {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 30rpx;
  color: #262626;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.result-detail {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
}

.result-distance {
  padding: 8rpx 16rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
}

.result-distance text {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
}

/* 已选目的地 */
.selected-destination {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f5ff 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 32rpx;
}

.selected-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.selected-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
}

.selected-text {
  flex: 1;
}

.selected-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.selected-detail {
  display: block;
  font-size: 26rpx;
  color: #595959;
}

.selected-actions {
  display: flex;
  gap: 20rpx;
}

.selected-actions .btn {
  flex: 1;
}

/* 历史记录 */
.history-section {
  padding: 32rpx;
}

.history-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.history-clear {
  font-size: 26rpx;
  color: #8c8c8c;
  padding: 8rpx 16rpx;
}

.history-clear:active {
  color: #1890ff;
}

.history-list {
  border-top: 2rpx solid #f0f0f0;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-route {
  display: flex;
  align-items: center;
}

.history-from,
.history-to {
  font-size: 28rpx;
  color: #262626;
  font-weight: 500;
}

.history-arrow {
  font-size: 28rpx;
  color: #8c8c8c;
  margin: 0 16rpx;
}

.history-time {
  font-size: 24rpx;
  color: #8c8c8c;
}
