.ar-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #020617;
}

.camera-layer {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.ar-webgl-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.lane-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 240rpx;
  height: 32vh;
  z-index: 3;
  pointer-events: none;
  overflow: hidden;
}

.lane-track {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 0;
  transform-origin: center bottom;
}

.lane-arrow {
  position: absolute;
  left: 50%;
  filter: drop-shadow(0 6rpx 14rpx rgba(37, 99, 235, 0.36));
}

.lane-arrow-0 {
  width: 148rpx;
  bottom: 182rpx;
  opacity: 0.52;
  transform: translateX(-50%) rotate(90deg) scaleY(0.22);
}

.lane-arrow-1 {
  width: 180rpx;
  bottom: 148rpx;
  opacity: 0.62;
  transform: translateX(-50%) rotate(90deg) scaleY(0.28);
}

.lane-arrow-2 {
  width: 220rpx;
  bottom: 112rpx;
  opacity: 0.72;
  transform: translateX(-50%) rotate(90deg) scaleY(0.35);
}

.lane-arrow-3 {
  width: 266rpx;
  bottom: 76rpx;
  opacity: 0.82;
  transform: translateX(-50%) rotate(90deg) scaleY(0.42);
}

.lane-arrow-4 {
  width: 316rpx;
  bottom: 40rpx;
  opacity: 0.9;
  transform: translateX(-50%) rotate(90deg) scaleY(0.5);
}

.lane-arrow-5 {
  width: 372rpx;
  bottom: 0rpx;
  opacity: 1;
  transform: translateX(-50%) rotate(90deg) scaleY(0.58);
}

.arrow-caption {
  position: absolute;
  left: 50%;
  bottom: 250rpx;
  transform: translateX(-50%);
  min-width: 240rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(2, 6, 23, 0.72);
  backdrop-filter: blur(18rpx);
  text-align: center;
}

.arrow-direction,
.arrow-angle {
  display: block;
}

.arrow-direction {
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
}

.arrow-angle {
  margin-top: 6rpx;
  color: #cbd5e1;
  font-size: 22rpx;
}

.top-panel {
  position: absolute;
  top: 48rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 4;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(2, 6, 23, 0.66);
  backdrop-filter: blur(24rpx);
}

.turn-around-tip {
  position: absolute;
  left: 50%;
  bottom: 340rpx;
  transform: translateX(-50%);
  z-index: 5;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(220, 38, 38, 0.86);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-label,
.destination-text,
.anchor-text,
.status-chip text,
.card-title,
.card-value,
.card-caption,
.motion-text,
.error-card text {
  display: block;
  color: #e2e8f0;
}

.mode-label {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #38bdf8;
}

.destination-text {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.anchor-text,
.card-caption,
.motion-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #cbd5e1;
}

.status-chip {
  position: absolute;
  top: 220rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 4;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
}

.bottom-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 48rpx;
  z-index: 4;
}

.arrival-banner {
  margin-bottom: 20rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.92) 0%, rgba(34, 197, 94, 0.92) 100%);
  box-shadow: 0 18rpx 40rpx rgba(22, 163, 74, 0.28);
}

.arrival-title,
.arrival-subtitle {
  display: block;
  color: #ecfeff;
}

.arrival-title {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.arrival-subtitle {
  font-size: 24rpx;
}

.info-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.76);
}

.card-title {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #38bdf8;
}

.card-value {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-row button,
.ghost-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.primary-btn {
  color: #022c22;
  background: linear-gradient(135deg, #4ade80 0%, #38bdf8 100%);
}

.secondary-btn {
  color: #e2e8f0;
  background: rgba(15, 23, 42, 0.88);
  border: 2rpx solid rgba(148, 163, 184, 0.3);
}

.ghost-btn {
  color: #e2e8f0;
  background: rgba(15, 23, 42, 0.62);
  border: 2rpx solid rgba(148, 163, 184, 0.24);
}

.error-card {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(127, 29, 29, 0.82);
}
