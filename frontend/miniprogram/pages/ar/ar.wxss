/* AR导航页面样式 - CSS 3D箭头 */
.ar-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

/* 相机层 */
.ar-camera-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.ar-camera {
  width: 100%;
  height: 100%;
  display: block;
}

/* 3D箭头层 */
.arrow-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* 3D箭头容器 */
.direction-arrow {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease, transform 0.1s ease;
}

.direction-arrow.visible {
  opacity: 1;
}

.direction-arrow.hidden {
  opacity: 0;
}

/* 箭头主体 */
.arrow-body {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 箭头头部 */
.arrow-head {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 0;
  height: 0;
  border-left: 50rpx solid transparent;
  border-right: 50rpx solid transparent;
  border-bottom: 120rpx solid #ff6b00;
  z-index: 10;
  filter: drop-shadow(0 0 10rpx rgba(255, 107, 0, 0.8));
}

.arrow-head::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: -40rpx;
  width: 0;
  height: 0;
  border-left: 40rpx solid transparent;
  border-right: 40rpx solid transparent;
  border-bottom: 100rpx solid rgba(255, 255, 255, 0.3);
}

/* 箭头尾部 */
.arrow-tail {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 20rpx);
  width: 30rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, #ff8800, #ff6b00);
  border-radius: 0 0 15rpx 15rpx;
  z-index: 8;
  box-shadow: 0 0 15rpx rgba(255, 136, 0, 0.6);
}

/* 箭头中心发光 */
.arrow-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.9) 0%, rgba(255, 200, 0, 0.6) 40%, transparent 70%);
  z-index: 15;
  animation: centerGlow 2s ease-in-out infinite;
}

@keyframes centerGlow {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.8;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.3);
    opacity: 1;
  }
}

/* 箭头装饰圈 */
.arrow-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 136, 0, 0.6);
  z-index: 5;
  box-shadow: 0 0 20rpx rgba(255, 136, 0, 0.4),
              inset 0 0 20rpx rgba(255, 136, 0, 0.2);
}

.arrow-ring::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 136, 0, 0.4);
}

/* 动态扫描线 */
.arrow-scanner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 180rpx;
  height: 180rpx;
  z-index: 6;
  animation: scannerSpin 3s linear infinite;
}

.arrow-scanner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 50%;
  background: linear-gradient(to bottom, rgba(0, 255, 255, 0.8), transparent);
  border-radius: 1rpx;
}

@keyframes scannerSpin {
  0% {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  100% {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* 脉动效果 */
.arrow-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 136, 0, 0.6);
  z-index: 3;
  pointer-events: none;
}

.arrow-pulse.pulse1 {
  animation: pulseExpand 2s ease-out infinite;
}

.arrow-pulse.pulse2 {
  animation: pulseExpand 2s ease-out 1s infinite;
}

@keyframes pulseExpand {
  0% {
    transform: translate(-50%, -50%) scale(0.6);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.8);
    opacity: 0;
  }
}

/* 导航信息面板 */
.distance-indicator {
  position: absolute;
  bottom: 240rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.distance-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 10rpx;
}

.distance-number {
  font-size: 60rpx;
  font-weight: 700;
  color: #ff6b00;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.distance-unit {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 10rpx;
}

.distance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 方向文字面板 */
.direction-text-panel {
  position: absolute;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  text-align: center;
  width: 80%;
}

.direction-main {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff8800;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.6);
  display: block;
  margin-bottom: 10rpx;
}

.instruction-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.5);
  display: block;
}

/* 顶部信息栏 */
.ar-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 20rpx 30rpx 40rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.destination-info {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.destination-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 10rpx;
}

.destination-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff8800;
}

.nav-stats {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-divider {
  color: rgba(255, 255, 255, 0.5);
}

/* 底部控制栏 */
.ar-control-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
  padding: 40rpx 30rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.control-left, .control-center, .control-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.control-left {
  flex: 1;
  justify-content: flex-start;
}

.control-center {
  flex: 1;
  justify-content: center;
}

.control-right {
  flex: 1;
  justify-content: flex-end;
}

.control-btn {
  min-width: 80rpx;
  padding: 0 20rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn::after {
  border: none;
}

.control-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.btn-label {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1;
}

.exit-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: rgba(245, 34, 45, 0.85);
  border-radius: 50%;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 10rpx 30rpx rgba(245, 34, 45, 0.45);
  padding: 0 !important;
  line-height: 1.2;
  margin: 0;
}

.exit-btn::after {
  border: none;
}

.exit-btn:active {
  transform: scale(0.95);
  background: rgba(245, 34, 45, 0.95);
}

.exit-btn .exit-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.exit-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
}

.exit-label text {
  display: block;
  width: 100%;
  text-align: center;
}

/* 到达提示 */
.arrival-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.arrival-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 100%;
  max-width: 600rpx;
  backdrop-filter: blur(10rpx);
}

.arrival-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b00;
  margin-bottom: 20rpx;
  display: block;
}

.arrival-message {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 40rpx;
  display: block;
}

.arrival-btn {
  min-width: 200rpx;
  padding: 0 40rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8800 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 0, 0.3);
}

.arrival-btn::after {
  border: none;
}

.arrival-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 0, 0.3);
}

/* 安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
