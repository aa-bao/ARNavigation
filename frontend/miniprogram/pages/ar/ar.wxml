<view class="ar-page">
  <camera class="camera-layer" device-position="back" flash="off"></camera>
  <canvas id="arWebglCanvas" type="webgl" class="ar-webgl-canvas" style="opacity: 0;"></canvas>

  <view class="lane-overlay" wx:if="{{!arrivedAtTarget && laneVisible && !rendererReady}}">
    <view class="lane-track" style="transform: translateX({{laneShiftRpx}}rpx) rotate({{laneRotateDeg}}deg);">
      <block wx:for="{{laneFrames}}" wx:key="*this">
        <image class="lane-arrow lane-arrow-{{index}}" src="/images/ar-lane-arrow.png" mode="aspectFit"></image>
      </block>
    </view>
    <view class="arrow-caption">
      <text class="arrow-direction">{{directionText}}</text>
      <text class="arrow-angle">相对角度 {{relativeAngle}}°</text>
    </view>
  </view>
  <view class="turn-around-tip" wx:if="{{!arrivedAtTarget && needTurnAround}}">
    <text>目标在身后，请转身</text>
  </view>

  <view class="top-panel">
    <text class="mode-label">AR 模式</text>
    <text class="destination-text">{{destination ? destination.nodeName || destination.name : '等待目标'}}</text>
    <text class="anchor-text">局部锚点：{{currentNode ? currentNode.nodeName : '未校准'}}</text>
  </view>

  <view class="status-chip">
    <text>{{rendererStatusText}}</text>
  </view>

  <view class="bottom-panel">
    <view class="arrival-banner" wx:if="{{arrivedAtTarget}}">
      <text class="arrival-title">已到达目的地</text>
      <text class="arrival-subtitle">{{destination ? destination.nodeName || destination.name : ''}}</text>
    </view>

    <view class="info-card">
      <text class="card-title">下一二维码点</text>
      <text class="card-value">{{nextNode ? nextNode.nodeName : '已到达最终目标'}}</text>
      <text class="card-caption">{{promptText}}</text>
      <text class="motion-text">{{motionText}}</text>
    </view>

    <view class="action-row">
      <button class="primary-btn" bindtap="handleRescan" loading="{{loading}}">
        重新扫码校准
      </button>
      <button class="secondary-btn" bindtap="switchToCompass">
        回到指南针
      </button>
    </view>

    <button class="ghost-btn" bindtap="endNavigation">
      结束导航
    </button>

    <view class="error-card" wx:if="{{errorText}}">
      <text>{{errorText}}</text>
    </view>
  </view>
</view>
