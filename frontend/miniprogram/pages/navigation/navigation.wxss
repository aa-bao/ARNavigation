/**pages/navigation/navigation.wxss**/
.navigation-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 顶部导航信息 */
.nav-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 32rpx;
  color: #ffffff;
}

.route-info {
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-point {
  text-align: center;
}

.location-point.start {
  flex: 1;
}

.location-point.end {
  flex: 1;
}

.point-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.point-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.route-arrow {
  font-size: 48rpx;
  margin: 0 32rpx;
  opacity: 0.9;
}

/* 主要导航界面 */
.nav-main {
  padding: 32rpx;
}

/* 方向指示器 */
/* 基础盒模型 */
.compass-container, .compass-rose, .arrow-wrapper, .direction-arrow {
  box-sizing: border-box;
}

.direction-indicator {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.compass-container {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compass-rose {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 8rpx solid #e8e8e8;
  border-radius: 50%;
  transition: transform 0.3s ease;
}

/* 统一罗盘方位文本样式 */
.compass-label {
  position: absolute;
  font-size: 24rpx;
  font-weight: 600;
  color: #8c8c8c;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compass-n { 
  top: 10rpx; 
  left: 50%; 
  transform: translateX(-50%); 
  color: #f5222d; 
}
.compass-s { 
  bottom: 10rpx; 
  left: 50%; 
  transform: translateX(-50%); 
}

.compass-e { 
  right: 10rpx; 
  top: 50%; 
  transform: translateY(-50%); 
}
.compass-w { 
  left: 10rpx; 
  top: 50%; 
  transform: translateY(-50%); 
}

/* 箭头容器居中 */
.arrow-wrapper {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120rpx;
  height: 120rpx;
  transform: translate(-50%, -50%); 
  pointer-events: none;
}

.direction-arrow {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  transition: transform 0.3s ease;
}

.direction-arrow text {
  font-size: 56rpx;
  color: #ffffff;
  margin-top: -6rpx; 
}

.direction-info {
  text-align: center;
}

.direction-text {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 16rpx;
}

.angle-info {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.angle-info text {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 导航信息卡片 */
.nav-info-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nav-instruction {
  display: flex;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.instruction-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.instruction-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.nav-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 32rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1890ff;
}

.stat-unit {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-left: 4rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e8e8e8;
}

.next-instruction {
  display: flex;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.next-label {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-right: 12rpx;
}

.next-text {
  font-size: 28rpx;
  color: #595959;
  font-weight: 500;
}

/* 路径节点列表 */
.path-section {
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 24rpx;
}

.path-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.path-node {
  display: flex;
  align-items: flex-start;
  position: relative;
}

.node-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  padding-top: 8rpx;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d9d9d9;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.node-line {
  width: 4rpx;
  flex: 1;
  min-height: 80rpx;
  background: #e8e8e8;
  margin: 8rpx 0;
}

.path-node.current .node-dot {
  background: #1890ff;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
  transform: scale(1.3);
}

.path-node.current .node-line {
  background: linear-gradient(180deg, #1890ff 0%, #e8e8e8 100%);
}

.path-node.completed .node-dot {
  background: #52c41a;
}

.path-node.completed .node-line {
  background: #52c41a;
}

.node-content {
  flex: 1;
  padding: 16rpx 0;
}

.node-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 8rpx;
}

.node-instruction {
  display: block;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.4;
}

.node-status {
  padding-top: 16rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.current {
  background: #e6f7ff;
  color: #1890ff;
}

.status-badge.completed {
  background: #f6ffed;
  color: #52c41a;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 2rpx solid #e8e8e8;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}

.action-left {
  display: flex;
  gap: 16rpx;
}

.action-right {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.96);
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #595959;
}

.action-btn.secondary:active {
  background: #e8e8e8;
}

.action-btn .btn-icon {
  margin-right: 6rpx;
  font-size: 26rpx;
}

.action-right .ar-btn {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
}

.action-right .ar-btn .btn-icon {
  font-size: 30rpx;
}

/* 暂停按钮样式 - 绿色 */
.action-btn.pause-btn {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(82, 196, 26, 0.3);
}

.action-btn.pause-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #389e0d 0%, #237804 100%);
}

/* 结束按钮样式 - 红色 */
.action-btn.end-btn {
  background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(245, 34, 45, 0.3);
}

.action-btn.end-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #cf1322 0%, #a8071a 100%);
}

/* 安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
