.navigation-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at top left, rgba(29, 78, 216, 0.18), transparent 32%),
    linear-gradient(180deg, #f6fbff 0%, #e6eff8 100%);
  box-sizing: border-box;
}

.hero-card,
.status-card,
.compass-card,
.prompt-card,
.error-card,
.arrival-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: #1d4ed8;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.title {
  display: block;
  margin-bottom: 10rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle,
.prompt-body,
.error-card text {
  color: #475569;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.22);
}

.status-row:last-child {
  border-bottom: 0;
}

.label {
  color: #64748b;
  font-size: 24rpx;
}

.value {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
}

.compass-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compass-shell {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 18rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
  border: 8rpx solid rgba(37, 99, 235, 0.16);
}

.compass-ring,
.compass-arrow {
  position: absolute;
  inset: 0;
}

.ring-label {
  position: absolute;
  color: #1e3a8a;
  font-size: 28rpx;
  font-weight: 700;
}

.north {
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
}

.south {
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
}

.east {
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
}

.west {
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
}

.compass-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #dc2626;
  font-size: 92rpx;
  font-weight: 700;
}

.direction-text {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.prompt-title {
  display: block;
  margin-bottom: 12rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.arrival-card {
  background: linear-gradient(135deg, #dcfce7 0%, #ccfbf1 100%);
  border: 2rpx solid rgba(16, 185, 129, 0.18);
}

.arrival-title,
.arrival-desc {
  display: block;
}

.arrival-title {
  margin-bottom: 8rpx;
  color: #047857;
  font-size: 34rpx;
  font-weight: 700;
}

.arrival-desc {
  color: #065f46;
  font-size: 26rpx;
}

.error-card {
  border: 2rpx solid rgba(220, 38, 38, 0.22);
  background: rgba(254, 242, 242, 0.94);
}

.action-group button {
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #0f766e 100%);
}

.secondary-btn {
  color: #0f172a;
  background: rgba(255, 255, 255, 0.88);
}

.ghost-btn {
  color: #475569;
  background: transparent;
  border: 2rpx solid rgba(100, 116, 139, 0.22);
}
