<view class="navigation-page">
  <view class="hero-card">
    <text class="eyebrow">指南针模式</text>
    <text class="title">{{destination ? destination.nodeName || destination.name : '等待目的地'}}</text>
    <text class="subtitle">{{instructionText}}</text>
  </view>

  <view class="arrival-card" wx:if="{{arrivedAtTarget}}">
    <text class="arrival-title">已到达目的地</text>
    <text class="arrival-desc">{{destination ? destination.nodeName || destination.name : ''}}</text>
  </view>

  <view class="status-card" wx:if="{{currentNode}}">
    <view class="status-row">
      <text class="label">当前扫码点</text>
      <text class="value">{{currentNode.nodeName}}</text>
    </view>
    <view class="status-row">
      <text class="label">下一二维码点</text>
      <text class="value">{{nextNode ? nextNode.nodeName : '已到达目标点'}}</text>
    </view>
    <view class="status-row">
      <text class="label">设备朝向</text>
      <text class="value">{{deviceDirection}}°</text>
    </view>
    <view class="status-row">
      <text class="label">目标朝向</text>
      <text class="value">{{targetDirection}}°</text>
    </view>
  </view>

  <view class="compass-card">
    <view class="compass-shell">
      <view class="compass-ring" style="transform: rotate({{-deviceDirection}}deg)">
        <text class="ring-label north">N</text>
        <text class="ring-label east">E</text>
        <text class="ring-label south">S</text>
        <text class="ring-label west">W</text>
      </view>
      <view class="compass-arrow" style="transform: rotate({{relativeAngle}}deg)">→</view>
    </view>
    <text class="direction-text">{{directionText}}</text>
  </view>

  <view class="prompt-card">
    <text class="prompt-title">校准策略</text>
    <text class="prompt-body">位置只以二维码扫描为准。请沿提示前往下一二维码点，到达后重新扫描。</text>
  </view>

  <view class="error-card" wx:if="{{errorText}}">
    <text>{{errorText}}</text>
  </view>

  <view class="action-group">
    <button class="primary-btn" bindtap="handleRescan" loading="{{loading}}">
      重新扫码校准
    </button>
    <button class="secondary-btn" bindtap="handleArrivedPrompt">
      我已到达下一点
    </button>
    <button class="secondary-btn" bindtap="enterARMode">
      切换到 AR 模式
    </button>
    <button class="ghost-btn" bindtap="endNavigation">
      结束导航
    </button>
  </view>
</view>
