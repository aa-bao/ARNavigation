<view class="container settings-container">
  <view class="login-entry-card" wx:if="{{!isLoggedIn}}">
    <view class="login-entry-title">登录后可同步你的导航记录</view>
    <view class="login-entry-desc">使用微信授权登录，不需要账号密码。</view>
    <button class="login-entry-btn" bindtap="goToLogin">微信授权登录</button>
  </view>

  <view class="user-card" wx:if="{{isLoggedIn && userInfo}}">
    <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || userInfo.nickname}}</text>
      <text class="user-id">ID: {{userInfo.id || '未知'}}</text>
    </view>
    <button class="avatar-upload-btn" bindtap="chooseAvatar">修改头像</button>
  </view>

  <view class="settings-group">
    <view class="group-title">功能设置</view>
    <view class="settings-list">
      <view class="setting-item">
        <view class="item-left">
          <image class="item-icon" src="/images/voice.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">语音播报</text>
            <text class="item-desc">导航时播报语音指令</text>
          </view>
        </view>
        <switch class="item-switch" checked="{{settings.voiceEnabled}}" data-field="voiceEnabled" bindchange="onSettingChange" />
      </view>

      <view class="setting-item">
        <view class="item-left">
          <image class="item-icon" src="/images/vibration.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">震动反馈</text>
            <text class="item-desc">导航时提供震动提示</text>
          </view>
        </view>
        <switch class="item-switch" checked="{{settings.vibrationEnabled}}" data-field="vibrationEnabled" bindchange="onSettingChange" />
      </view>

      <view class="setting-item">
        <view class="item-left">
          <image class="item-icon" src="/images/location.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">高精度定位</text>
            <text class="item-desc">使用GPS和网络提高精度</text>
          </view>
        </view>
        <switch class="item-switch" checked="{{settings.highAccuracyLocation}}" data-field="highAccuracyLocation" bindchange="onSettingChange" />
      </view>

      <view class="setting-item">
        <view class="item-left">
          <image class="item-icon" src="/images/ar.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">自动启动AR</text>
            <text class="item-desc">导航时自动进入AR模式</text>
          </view>
        </view>
        <switch class="item-switch" checked="{{settings.autoStartAR}}" data-field="autoStartAR" bindchange="onSettingChange" />
      </view>
    </view>
  </view>

  <view class="settings-group">
    <view class="group-title">权限管理</view>
    <view class="settings-list">
      <view class="setting-item" bindtap="goToPermissionSettings">
        <view class="item-left">
          <image class="item-icon" src="/images/permission.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">应用权限</text>
            <text class="item-desc">管理位置、相机等权限</text>
          </view>
        </view>
        <image class="item-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="settings-group">
    <view class="group-title">其他</view>
    <view class="settings-list">
      <view class="setting-item" bindtap="clearCache">
        <view class="item-left">
          <image class="item-icon" src="/images/clear.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">清除缓存</text>
            <text class="item-desc">当前缓存: {{cacheInfo.size}}MB</text>
          </view>
        </view>
        <image class="item-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>

      <view class="setting-item" bindtap="checkUpdate">
        <view class="item-left">
          <image class="item-icon" src="/images/update.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">检查更新</text>
            <text class="item-desc">当前版本: {{appInfo.version}}</text>
          </view>
        </view>
        <image class="item-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>

      <view class="setting-item" bindtap="aboutUs">
        <view class="item-left">
          <image class="item-icon" src="/images/about.png" mode="aspectFit"></image>
          <view class="item-content">
            <text class="item-title">关于我们</text>
            <text class="item-desc">了解医院AR导航系统</text>
          </view>
        </view>
        <image class="item-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
