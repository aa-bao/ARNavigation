/**pages/settings/settings.wxss**/
.settings-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  margin: 32rpx;
  padding: 40rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.3);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 32rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 设置组 */
.settings-group {
  margin: 0 32rpx 32rpx;
}

.group-title {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.settings-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: #262626;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
}

.item-switch {
  transform: scale(0.8);
}

.item-arrow {
  width: 32rpx;
  height: 32rpx;
  margin-left: 16rpx;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
