.map-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 52rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(16, 185, 129, 0.16), transparent 28%),
    linear-gradient(180deg, #f7fbf9 0%, #e7f0ec 100%);
}

.hero-card,
.map-card,
.summary-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: #0f766e;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.title {
  display: block;
  margin-bottom: 10rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  color: #475569;
  font-size: 26rpx;
  line-height: 1.6;
}

.floor-switcher {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.floor-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  margin-right: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
}

.floor-chip.active {
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  color: #ffffff;
}

.map-card {
  position: relative;
}

.map-stage {
  position: relative;
}

.map-image {
  width: 100%;
  border-radius: 20rpx;
  background: #f8fafc;
}

.marker-layer {
  position: absolute;
  inset: 0;
}

.marker {
  position: absolute;
  transform: translate(-50%, -50%);
}

.marker-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 8rpx rgba(15, 23, 42, 0.08);
}

.marker-CURRENT .marker-dot {
  background: #2563eb;
  animation: pulse 2.2s ease-in-out infinite;
}

.marker-DESTINATION .marker-dot {
  background: #dc2626;
}

.marker-label {
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #0f172a;
  font-size: 22rpx;
  white-space: nowrap;
}

.overview-tip,
.state-card text {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.overview-tip {
  margin-top: 18rpx;
}

.state-card {
  padding: 12rpx 0;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.22);
}

.summary-row:last-child {
  border-bottom: 0;
}

.summary-label {
  color: #64748b;
  font-size: 24rpx;
}

.summary-value {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }

  50% {
    transform: scale(1.16);
    opacity: 0.72;
  }
}
