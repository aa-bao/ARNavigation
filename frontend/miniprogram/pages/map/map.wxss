.map-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 52rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(16, 185, 129, 0.16), transparent 28%),
    linear-gradient(180deg, #f7fbf9 0%, #e7f0ec 100%);
}

.hero-card,
.map-card,
.summary-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: #0f766e;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.title {
  display: block;
  margin-bottom: 10rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  color: #475569;
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-actions {
  margin-top: 14rpx;
}

.hero-action-btn {
  margin: 0;
  width: 180rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
  font-size: 22rpx;
  border: 0;
}

.floor-switcher {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.floor-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  margin-right: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
}

.floor-chip.active {
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  color: #ffffff;
}

.map-stage {
  width: 100%;
  overflow: hidden;
  border-radius: 20rpx;
  background: #f8fafc;
}

.map-canvas {
  display: block;
  width: 100%;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  color: #475569;
  font-size: 22rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.state-card {
  margin-top: 18rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.state-card.warning {
  color: #b45309;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.22);
}

.summary-row:last-child {
  border-bottom: 0;
}

.summary-label {
  color: #64748b;
  font-size: 24rpx;
}

.summary-value {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
}
