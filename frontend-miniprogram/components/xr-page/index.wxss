/* XR页面容器样式 */

.xr-page-container {
  position: relative;
  overflow: hidden;
  background: #000;
}

.xr-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.xr-slot-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.xr-slot-content > * {
  pointer-events: auto;
}

.xr-ar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 20;
  pointer-events: none;
}

.xr-ar-overlay > * {
  pointer-events: auto;
}
