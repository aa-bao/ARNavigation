/* AR视觉导引页面样式 */

/* XR页面容器 */
xr-page {
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* UI层容器 */
.ar-ui-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  z-index: 100;
}

.ar-ui-container > view {
  pointer-events: auto;
}

/* 顶部导航信息 */
.nav-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 20rpx;
}

.back-btn image {
  width: 32rpx;
  height: 32rpx;
}

.nav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.destination {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.remaining-distance {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 指南针指示器 */
.compass-indicator {
  position: absolute;
  top: 140rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  transition: transform 0.3s ease-out;
}

.compass-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(0,0,0,0.4);
  border: 2rpx solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.compass-needle {
  position: absolute;
  width: 4rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #ff4444 0%, #ff4444 50%, #ffffff 50%, #ffffff 100%);
  border-radius: 2rpx;
  top: 10rpx;
}

.compass-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #ff4444;
  position: absolute;
  top: 4rpx;
}

/* AR指引信息 - 高德地图风格 */
.ar-guidance {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}

.direction-hint {
  background: linear-gradient(135deg, rgba(0,0,0,0.75) 0%, rgba(20,20,30,0.85) 100%);
  padding: 24rpx 50rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(0,212,255,0.3);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.4),
              0 0 20rpx rgba(0,212,255,0.15) inset;
  position: relative;
  overflow: hidden;
}

/* 高光效果 */
.direction-hint::before {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { left: -50%; }
  100% { left: 150%; }
}

.hint-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 0 20rpx rgba(0,212,255,0.5);
  letter-spacing: 2rpx;
}

.turn-angle {
  font-size: 32rpx;
  color: #00d4ff;
  background: linear-gradient(135deg, rgba(0,212,255,0.3) 0%, rgba(0,153,204,0.3) 100%);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: bold;
  border: 1rpx solid rgba(0,212,255,0.5);
  box-shadow: 0 0 15rpx rgba(0,212,255,0.3);
}

.next-point {
  background: linear-gradient(135deg, rgba(0,50,80,0.6) 0%, rgba(0,30,60,0.7) 100%);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border: 1rpx solid rgba(0,212,255,0.4);
  backdrop-filter: blur(15rpx);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.next-point text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.95);
}

.point-distance {
  font-size: 32rpx;
  font-weight: bold;
  color: #00d4ff !important;
  text-shadow: 0 0 10rpx rgba(0,212,255,0.5);
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  transition: all 0.3s ease;
}

.action-btn:active {
  background: rgba(255,255,255,0.25);
  transform: scale(0.95);
}

.action-btn.exit-btn {
  background: rgba(255,80,80,0.2);
  border-color: rgba(255,80,80,0.4);
}

.action-btn.exit-btn:active {
  background: rgba(255,80,80,0.3);
}

.action-btn image {
  width: 48rpx;
  height: 48rpx;
}

.action-btn text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

/* 提示信息 */
.toast {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.8);
  padding: 30rpx 50rpx;
  border-radius: 20rpx;
  z-index: 1000;
}

.toast text {
  font-size: 30rpx;
  color: #ffffff;
}

/* 校准提示弹窗 */
.calibration-modal {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  backdrop-filter: blur(5rpx);
}

.calibration-content {
  background: rgba(40,40,50,0.95);
  padding: 60rpx 50rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  max-width: 80%;
}

.calibration-content image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.8;
}

.calibration-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.calibration-tip {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  text-align: center;
  line-height: 1.6;
}

.calibration-btn {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

.calibration-btn:active {
  opacity: 0.8;
}

/* 到达终点提示 */
.arrival-modal {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3000;
}

.arrival-content {
  background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(0,153,204,0.2));
  padding: 80rpx 60rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(0,212,255,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.arrival-icon {
  width: 120rpx;
  height: 120rpx;
  background: rgba(0,212,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrival-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #00d4ff;
}

.arrival-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.arrival-btn {
  margin-top: 30rpx;
  padding: 25rpx 80rpx;
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}
