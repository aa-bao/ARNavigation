<!-- AR视觉导引页面 - 基于XR-FRAME框架 -->
<xr-page
  bind:ready="handleXRReady"
  bind:arReady="handleARReady"
  bind:error="handleXRError"
>
  <xr-scene
    id="main-scene"
    bind:ready="handleSceneReady"
  >
    <!-- 相机配置 -->
    <xr-camera
      id="main-camera"
      clear-color="0 0 0 0"
      background="ar"
      is-ar-camera
      near="0.01"
      far="1000"
    />

    <!-- 环境光照 -->
    <xr-light
      id="ambient-light"
      type="ambient"
      intensity="0.6"
      color="1 1 1"
    />
    <xr-light
      id="directional-light"
      type="directional"
      intensity="0.8"
      color="1 1 1"
      position="10 10 5"
    />

    <!-- AR导航箭头容器 -->
    <xr-node
      id="arrow-container"
      visible="{{arrowVisible}}"
      position="{{arrowPosition}}"
      rotation="{{arrowRotation}}"
      scale="{{arrowScale}}"
    >
      <!-- 3D立体箭头 - 类似高德地图AR导航箭头 -->

      <!-- 箭头主体：三棱柱 + 锥体 -->
      <xr-node id="arrow-main">
        <!-- 箭头底座（圆环） -->
        <xr-mesh
          id="arrow-base"
          geometry="ring"
          material="arrow-base-material"
          scale="1.2 1.2 1.2"
          rotation="90 0 0"
          position="0 0.05 0"
        />

        <!-- 箭头主体柱 -->
        <xr-mesh
          id="arrow-body"
          geometry="cylinder"
          material="arrow-body-material"
          scale="0.3 0.8 0.3"
          position="0 0.4 0"
        />

        <!-- 箭头头部（锥体） -->
        <xr-mesh
          id="arrow-head"
          geometry="cone"
          material="arrow-head-material"
          scale="0.6 0.8 0.6"
          position="0 1.2 0"
          rotation="180 0 0"
        />

        <!-- 箭头装饰环 -->
        <xr-mesh
          id="arrow-ring1"
          geometry="ring"
          material="arrow-ring-material"
          scale="0.8 0.8 0.8"
          rotation="90 0 0"
          position="0 0.7 0"
        />
        <xr-mesh
          id="arrow-ring2"
          geometry="ring"
          material="arrow-ring-material"
          scale="0.6 0.6 0.6"
          rotation="90 0 0"
          position="0 1.0 0"
        />
      </xr-node>

      <!-- 箭头尾焰/光晕效果 -->
      <xr-node id="arrow-tail">
        <xr-mesh
          id="tail-glow1"
          geometry="cone"
          material="tail-glow-material"
          scale="1.5 1.5 1.5"
          position="0 -0.2 0"
          rotation="0 0 0"
        />
        <xr-mesh
          id="tail-glow2"
          geometry="cone"
          material="tail-glow2-material"
          scale="1.8 1.8 1.8"
          position="0 -0.3 0"
          rotation="0 0 0"
        />
      </xr-node>

      <!-- 距离指示环 -->
      <xr-mesh
        id="distance-ring"
        geometry="ring"
        material="ring-material"
        scale="2 2 2"
        rotation="90 0 0"
        position="0 0.1 0"
      />
    </xr-node>

    <!-- 目标点标记 -->
    <xr-node
      id="target-marker"
      visible="{{targetVisible}}"
      position="{{targetPosition}}"
    >
      <xr-mesh
        id="target-icon"
        geometry="sphere"
        material="target-material"
        scale="0.3 0.3 0.3"
      />
    </xr-node>

    <!-- 材质定义 - 高德风格3D箭头材质 -->
    <xr-asset-material
      id="arrow-material"
      effect="standard"
      uniforms="diffuseColor: 0 0.7 1 1; emissiveColor: 0 0.3 0.5 1"
    />

    <!-- 箭头底座材质 -->
    <xr-asset-material
      id="arrow-base-material"
      effect="standard"
      uniforms="diffuseColor: 0 0.5 0.8 0.8; emissiveColor: 0 0.3 0.6 0.6"
      transparent
    />

    <!-- 箭头主体材质 - 亮青色 -->
    <xr-asset-material
      id="arrow-body-material"
      effect="standard"
      uniforms="diffuseColor: 0 0.85 1 1; emissiveColor: 0 0.5 0.8 1"
    />

    <!-- 箭头头部材质 - 亮白色发光 -->
    <xr-asset-material
      id="arrow-head-material"
      effect="standard"
      uniforms="diffuseColor: 0.9 0.95 1 1; emissiveColor: 0 0.8 1 1"
    />

    <!-- 箭头装饰环材质 -->
    <xr-asset-material
      id="arrow-ring-material"
      effect="standard"
      uniforms="diffuseColor: 1 1 1 0.9; emissiveColor: 0.8 0.9 1 0.8"
      transparent
    />

    <!-- 尾焰光晕材质 - 外层 -->
    <xr-asset-material
      id="tail-glow-material"
      effect="standard"
      uniforms="diffuseColor: 0 0.8 1 0.3; emissiveColor: 0 0.6 1 0.4"
      transparent
    />

    <!-- 尾焰光晕材质 - 内层 -->
    <xr-asset-material
      id="tail-glow2-material"
      effect="standard"
      uniforms="diffuseColor: 0 0.9 1 0.2; emissiveColor: 0 0.7 1 0.3"
      transparent
    />

    <!-- 距离指示环材质 -->
    <xr-asset-material
      id="ring-material"
      effect="standard"
      uniforms="diffuseColor: 0.2 0.8 1 0.5; emissiveColor: 0 0.5 0.8 0.3"
      transparent
    />

    <!-- 目标点材质 -->
    <xr-asset-material
      id="target-material"
      effect="standard"
      uniforms="diffuseColor: 1 0.2 0.2 1; emissiveColor: 0.8 0 0 1"
    />
  </xr-scene>

  <!-- UI层 -->
  <view class="ar-ui-container">
    <!-- 顶部导航信息 -->
    <view class="nav-header">
      <view class="back-btn" bindtap="goBack">
        <image src="/images/back.png" mode="aspectFit"/>
      </view>
      <view class="nav-info">
        <text class="destination">{{destinationName}}</text>
        <text class="remaining-distance">剩余 {{remainingDistance}} 米</text>
      </view>
    </view>

    <!-- 指南针指示器 -->
    <view class="compass-indicator" style="transform: rotate({{compassRotation}}deg)">
      <view class="compass-bg">
        <view class="compass-needle"></view>
        <text class="compass-text">N</text>
      </view>
    </view>

    <!-- AR指引信息 -->
    <view class="ar-guidance">
      <view class="direction-hint">
        <text class="hint-text">{{directionHint}}</text>
        <text class="turn-angle" wx:if="{{turnAngle > 0}}">{{turnAngle}}°</text>
      </view>
      <view class="next-point">
        <text>下一点：{{nextPointName}}</text>
        <text class="point-distance">{{nextPointDistance}}m</text>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="action-bar">
      <view class="action-btn" bindtap="recenterView">
        <image src="/images/center.png" mode="aspectFit"/>
        <text>重置视角</text>
      </view>
      <view class="action-btn exit-btn" bindtap="exitAR">
        <image src="/images/exit.png" mode="aspectFit"/>
        <text>退出AR</text>
      </view>
    </view>
  </view>

  <!-- 提示弹窗 -->
  <view class="toast" wx:if="{{showToast}}">
    <text>{{toastMessage}}</text>
  </view>

  <!-- 校准提示 -->
  <view class="calibration-modal" wx:if="{{showCalibration}}">
    <view class="calibration-content">
      <image src="/images/calibrate.png" mode="aspectFit"/>
      <text class="calibration-title">请校准指南针</text>
      <text class="calibration-tip">请按照图示方式移动手机，画8字形进行校准</text>
      <button class="calibration-btn" bindtap="dismissCalibration">我知道了</button>
    </view>
  </view>
</xr-page>